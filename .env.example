# Firebase web config (Project settings → General → Your apps → SDK setup → Config).
# These are NOT secret (web config is public). Copy to `.env` and fill in.
# If left empty, the app runs Phase-1 offline (localStorage presets) with no Firebase.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=led-text-light.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=led-text-light
VITE_FIREBASE_STORAGE_BUCKET=led-text-light.appspot.com
VITE_FIREBASE_MSG_SENDER_ID=
VITE_FIREBASE_APP_ID=
