rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Presets are private to their owner (anonymous uid). ADR-0005.
    match /users/{uid}/presets/{presetId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Shows (Phase 3 broadcast, reserved). Anyone may read to mirror; only the
    // Controller who created it (ownerUid) may push/update/delete. ADR-0004.
    match /shows/{code} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
